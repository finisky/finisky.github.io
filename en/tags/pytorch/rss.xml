&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; File &lt;span class="s2"&gt;&amp;#34;test.py&amp;#34;&lt;/span&gt;, line 3, in &amp;lt;module&amp;gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; ...
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; File &lt;span class="s2"&gt;&amp;#34;miniconda3/envs/torch/lib/python3.7/site-packages/apex/__init__.py&amp;#34;&lt;/span&gt;, line 18, in &amp;lt;module&amp;gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; from apex.interfaces import &lt;span class="o"&gt;(&lt;/span&gt;ApexImplementation,
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; File &lt;span class="s2"&gt;&amp;#34;miniconda3/envs/torch/lib/python3.7/site-packages/apex/interfaces.py&amp;#34;&lt;/span&gt;, line 10, in &amp;lt;module&amp;gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; class ApexImplementation&lt;span class="o"&gt;(&lt;/span&gt;object&lt;span class="o"&gt;)&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; File &lt;span class="s2"&gt;&amp;#34;miniconda3/envs/torch/lib/python3.7/site-packages/apex/interfaces.py&amp;#34;&lt;/span&gt;, line 14, in ApexImplementation
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; implements&lt;span class="o"&gt;(&lt;/span&gt;IApex&lt;span class="o"&gt;)&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; File &lt;span class="s2"&gt;&amp;#34;miniconda3/envs/torch/lib/python3.7/site-packages/zope/interface/declarations.py&amp;#34;&lt;/span&gt;, line 483, in implements
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; raise TypeError&lt;span class="o"&gt;(&lt;/span&gt;_ADVICE_ERROR % &lt;span class="s1"&gt;&amp;#39;implementer&amp;#39;&lt;/span&gt;&lt;span class="o"&gt;)&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;TypeError: Class advice impossible in Python3. Use the @implementer class decorator instead.&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;
